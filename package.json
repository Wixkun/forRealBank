{
  "name": "forrealbank",
  "private": true,
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": "^20.11.0 || ^22.0"
  },
  "scripts": {
    "build": "pnpm -r --filter @forreal/domain build && pnpm -r --filter @forreal/application build && pnpm -r --filter api-nest build",
    "dev": "pnpm -r --parallel dev",
    "dev:local": "pnpm --parallel --filter api-nest --filter web-next dev",
    "dev:local:poll": "pnpm --parallel --filter api-nest --filter web-next dev:poll",
    "dev:local:webpack": "pnpm --parallel --filter api-nest --filter web-next dev:webpack",
    "dev:local:poll:webpack": "pnpm --parallel --filter api-nest --filter web-next dev:poll:webpack",
    "lint": "pnpm -r lint",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down -v",
    "bootstrap": "pnpm install --force && pnpm -r build",
    "dk:up": "docker compose up --build",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build",
    "docker:prod": "docker compose -f docker-compose.yml up --build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^20.11.0",
    "globals": "^17.1.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1"
  },
  "dependencies": {
    "react-icons": "^5.5.0"
  }
}
