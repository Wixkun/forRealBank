{
  "name": "forrealbank",
  "private": true,
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": "^22.13.0 || ^24.0"
  },
  "scripts": {
    "build": "pnpm -r --filter @forreal/domain build && pnpm -r --filter @forreal/application build && pnpm -r --filter @forreal/infrastructure-* build && pnpm -r --filter api-nest build && pnpm -r --filter web-next build",
    "prepare": "node scripts/setup-git-hooks.cjs",
    "dev": "pnpm -r --parallel dev",
    "dev:local": "docker compose up db pgadmin -d && pnpm --parallel --filter api-nest --filter web-next dev",
    "dev:local:poll": "pnpm --parallel --filter api-nest --filter web-next dev:poll",
    "dev:local:webpack": "pnpm --parallel --filter api-nest --filter web-next dev:webpack",
    "dev:local:poll:webpack": "pnpm --parallel --filter api-nest --filter web-next dev:poll:webpack",
    "lint": "pnpm -r --if-present lint",
    "lint:fix": "pnpm -r --if-present lint:fix",
    "format": "pnpm prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test:unit": "pnpm -r --if-present test:unit",
    "test:e2e": "pnpm -r --if-present test:e2e",
    "ci:verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test:unit && pnpm build",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down -v",
    "bootstrap": "pnpm install --force && pnpm -r build",
    "dk:up": "docker compose up --build",
    "docker:dev": "docker compose -f docker-compose.override.yml up --build",
    "docker:prod": "docker compose -f docker-compose.yml up --build",
    "test": "pnpm -r --if-present test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^20.11.0",
    "globals": "^17.1.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1"
  }
}
