      "options": {
        "reduceOptions": { "values": false, "fields": "", "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [{ "expr": "count(up{job=\"node-exporter\"} == 1)", "refId": "A" }],
