{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "baseUrl": ".",
    "paths": {
      "@forreal/domain": ["packages/domain/src"],
      "@forreal/application": ["packages/application/src"],
      "@forreal/infrastructure-typeorm": ["packages/infrastructure/typeorm/src"],
      "@forreal/infrastructure-crypto-bcrypt": ["packages/infrastructure/crypto-bcrypt/src"],
      "@forreal/infrastructure-jwt-nest": ["packages/infrastructure/jwt-nest/src"],
      "@forreal/infrastructure-uuid-node": ["packages/infrastructure/uuid-node/src"]
    }
  }
}
