{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "rootDir": ".",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@forreal/domain": ["../../packages/domain/dist/index.d.ts"],
      "@forreal/domain/*": ["../../packages/domain/dist/*"],
      "@forreal/application": ["../../packages/application/dist/index.d.ts"],
      "@forreal/application/*": ["../../packages/application/dist/*"],
      "@forreal/infrastructure-typeorm": ["../../packages/infrastructure/typeorm/dist/index.d.ts"],
      "@forreal/infrastructure-typeorm/*": ["../../packages/infrastructure/typeorm/dist/*"],
      "@forreal/infrastructure-mongodb": ["../../packages/infrastructure/mongodb/dist/index.d.ts"],
      "@forreal/infrastructure-mongodb/*": ["../../packages/infrastructure/mongodb/dist/*"]
    },
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
